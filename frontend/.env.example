# Copy this file to .env.local (gitignored) and fill in your deployed contract addresses.
# Vite only exposes VITE_-prefixed variables to the browser bundle.

# Local Anvil（每次重启 anvil 重新部署后地址通常不变，因为 nonce 是确定的）
VITE_GUESS_CHAMPION_ANVIL=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Sepolia testnet（部署后从 broadcast/...run-latest.json 取 contractAddress）
VITE_GUESS_CHAMPION_SEPOLIA=0x0000000000000000000000000000000000000000

# Mainnet（学习项目通常不用）
# VITE_GUESS_CHAMPION_MAINNET=0x0000000000000000000000000000000000000000
